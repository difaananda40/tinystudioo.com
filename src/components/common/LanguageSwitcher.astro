---
import { languages } from "i18n/translations";
import { getRelativeLocaleUrl } from "astro:i18n";
import { getLangFromUrl } from "i18n/utils";

const currentLang = getLangFromUrl(Astro.url);

const path = Astro.url.pathname
    .replace(`/${currentLang}`, "")
    .replace(/^\//, "");

const currentLabel =
    languages[currentLang as keyof typeof languages] ??
    currentLang.toUpperCase();
---

<div class="relative inline-block" data-lang-switcher>
    <button
        type="button"
        data-lang-trigger
        class="inline-flex items-center gap-2 rounded-lg border border-gray-200 dark:border-white/10 bg-white/10 dark:bg-black/20 backdrop-blur-lg px-3 py-1.5 text-sm font-medium text-gray-700 dark:text-gray-200 hover:bg-white/20 dark:hover:bg-white/5 transition-all duration-300"
        aria-haspopup="listbox"
        aria-expanded="false"
    >
        <span class="font-normal uppercase">{currentLabel}</span>
        <svg
            class="w-4 h-4 opacity-70 transition-transform duration-300"
            data-arrow
            viewBox="0 0 20 20"
            fill="currentColor"
            aria-hidden="true"
        >
            <path
                fill-rule="evenodd"
                d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.51a.75.75 0 01-1.08 0l-4.25-4.51a.75.75 0 01.02-1.06z"
                clip-rule="evenodd"></path>
        </svg>
    </button>

    <ul
        data-lang-menu
        role="listbox"
        class="absolute right-0 mt-2 min-w-[110px] rounded-xl border border-gray-200 dark:border-white/10 bg-white/10 dark:bg-black/40 backdrop-blur-xl p-1.5 hidden z-50 uppercase transition-all duration-300 origin-top-right"
    >
        {
            Object.entries(languages).map(([lang, label]) => {
                const active = lang === currentLang;
                return (
                    <li role="option" aria-selected={active}>
                        <a
                            href={getRelativeLocaleUrl(lang, path)}
                            class={`flex items-center justify-between rounded-md px-3 py-2 text-xs transition-all ${
                                active
                                    ? "bg-white/20 dark:bg-white/10 text-black dark:text-white font-semibold"
                                    : "text-gray-700 dark:text-gray-200 hover:bg-white/20 dark:hover:bg-white/5"
                            }`}
                        >
                            {label}
                            {active && (
                                <span class="w-1.5 h-1.5 rounded-full bg-red-500 dark:bg-blue-500 shadow-[0_0_8px_rgba(239,68,68,0.6)]" />
                            )}
                        </a>
                    </li>
                );
            })
        }
    </ul>
</div>

<script>
    function initLanguageSwitcher(): void {
        const roots = document.querySelectorAll<HTMLElement>(
            "[data-lang-switcher]",
        );

        roots.forEach((root) => {
            const trigger = root.querySelector<HTMLButtonElement>(
                "[data-lang-trigger]",
            );
            const menu =
                root.querySelector<HTMLUListElement>("[data-lang-menu]");
            const arrow = root.querySelector<SVGElement>("[data-arrow]");

            if (!trigger || !menu) return;
            if (trigger.dataset.bound === "true") return;

            const toggleMenu = (show: boolean): void => {
                if (show) {
                    menu.classList.remove("hidden");
                    trigger.setAttribute("aria-expanded", "true");
                    arrow?.classList.add("rotate-180");
                } else {
                    menu.classList.add("hidden");
                    trigger.setAttribute("aria-expanded", "false");
                    arrow?.classList.remove("rotate-180");
                }
            };

            trigger.addEventListener("click", (e: MouseEvent) => {
                e.stopPropagation();
                const isHidden = menu.classList.contains("hidden");
                toggleMenu(isHidden);
            });

            document.addEventListener("click", (e: MouseEvent) => {
                if (!root.contains(e.target as Node)) toggleMenu(false);
            });

            document.addEventListener("keydown", (e: KeyboardEvent) => {
                if (e.key === "Escape") toggleMenu(false);
            });

            trigger.dataset.bound = "true";
        });
    }

    initLanguageSwitcher();
    document.addEventListener("astro:after-swap", initLanguageSwitcher);
</script>
