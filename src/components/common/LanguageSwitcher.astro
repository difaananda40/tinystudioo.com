---
import { languages } from "i18n/translations";
import { getRelativeLocaleUrl } from "astro:i18n";
import { getLangFromUrl } from "i18n/utils";

const currentLang = getLangFromUrl(Astro.url);

const path = Astro.url.pathname
    .replace(`/${currentLang}`, "")
    .replace(/^\//, "");

const currentLabel =
    languages[currentLang as keyof typeof languages] ??
    currentLang.toUpperCase();
---

<div class="relative inline-block" data-lang-switcher>
    <button
        type="button"
        data-lang-trigger
        class="inline-flex items-center gap-2 rounded-lg border border-gray-200/80 dark:border-gray-700/80 bg-white/30 dark:bg-gray-900/80 px-3 py-1.5 text-sm font-normal text-gray-700 dark:text-gray-200 shadow-sm hover:border-gray-300 dark:hover:border-gray-500 transition"
        aria-haspopup="listbox"
        aria-expanded="false"
    >
        <span class="font-normal uppercase">{currentLabel}</span>
        <svg
            class="w-4 h-4 opacity-70"
            viewBox="0 0 20 20"
            fill="currentColor"
            aria-hidden="true"
        >
            <path
                fill-rule="evenodd"
                d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.51a.75.75 0 01-1.08 0l-4.25-4.51a.75.75 0 01.02-1.06z"
                clip-rule="evenodd"></path>
        </svg>
    </button>

    <ul
        data-lang-menu
        role="listbox"
        class="absolute right-0 mt-2 min-w-[90px] rounded-lg border border-gray-200/80 dark:border-gray-700/80 bg-white/95 dark:bg-gray-900/95 backdrop-blur p-1 shadow-lg hidden z-50 uppercase"
    >
        {
            Object.entries(languages).map(([lang, label]) => {
                const active = lang === currentLang;
                return (
                    <li role="option" aria-selected={active}>
                        <a
                            href={getRelativeLocaleUrl(lang, path)}
                            class={`flex items-center justify-between rounded-md px-3 py-2 text-sm transition ${
                                active
                                    ? "bg-gray-100 dark:bg-gray-800 text-black dark:text-white font-medium"
                                    : "text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-800/70"
                            }`}
                        >
                            {label}
                        </a>
                    </li>
                );
            })
        }
    </ul>
</div>

<script>
    function initLanguageSwitcher(): void {
        const roots = document.querySelectorAll<HTMLElement>(
            "[data-lang-switcher]",
        );

        roots.forEach((root) => {
            const trigger = root.querySelector<HTMLButtonElement>(
                "[data-lang-trigger]",
            );
            const menu =
                root.querySelector<HTMLUListElement>("[data-lang-menu]");

            if (!trigger || !menu) return;
            if (trigger.dataset.bound === "true") return;

            const closeMenu = (): void => {
                menu.classList.add("hidden");
                trigger.setAttribute("aria-expanded", "false");
            };

            trigger.addEventListener("click", (e: MouseEvent) => {
                e.stopPropagation();
                const isHidden = menu.classList.contains("hidden");
                if (isHidden) {
                    menu.classList.remove("hidden");
                    trigger.setAttribute("aria-expanded", "true");
                } else {
                    closeMenu();
                }
            });

            document.addEventListener("click", (e: MouseEvent) => {
                const target = e.target;
                if (!(target instanceof Node)) return;
                if (!root.contains(target)) closeMenu();
            });

            document.addEventListener("keydown", (e: KeyboardEvent) => {
                if (e.key === "Escape") closeMenu();
            });

            trigger.dataset.bound = "true";
        });
    }

    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initLanguageSwitcher, {
            once: true,
        });
    } else {
        initLanguageSwitcher();
    }

    document.addEventListener("astro:after-swap", initLanguageSwitcher);
</script>
